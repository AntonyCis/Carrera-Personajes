<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="700.0"
            style="-fx-background-color: #000;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controlador.CarreraControlador">
   <children>
      <ImageView fitHeight="400.0" fitWidth="700.0" opacity="0.8" pickOnBounds="true"
                 AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                 AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <image>
            <Image url="@Imagenes/paisaje.jpg" />
         </image>
      </ImageView>

      <HBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox fx:id="vboxPersonajes" alignment="CENTER_LEFT" prefWidth="180.0" spacing="25.0"
                  style="-fx-background-color: rgba(0,0,0,0.4); -fx-background-radius: 0 20 20 0;">
               <children>
                  <ImageView fx:id="Img1" fitHeight="75.0" fitWidth="75.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@Imagenes/arthas.png" /></image>
                     <effect><DropShadow blurType="GAUSSIAN" color="#00e5ff" /> </effect>
                  </ImageView>

                  <ImageView fx:id="Img2" fitHeight="75.0" fitWidth="75.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@Imagenes/Illidan.png" /></image>
                     <effect><DropShadow blurType="GAUSSIAN" color="#2bff00" /> </effect>
                  </ImageView>

                  <ImageView fx:id="Img3" fitHeight="75.0" fitWidth="75.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@Imagenes/thrall.png" /></image>
                     <effect><DropShadow blurType="GAUSSIAN" color="#ff9500" /> </effect>
                  </ImageView>
               </children>
               <padding>
                  <Insets left="25.0" />
               </padding>
               <effect>
                  <DropShadow radius="15.0" width="31.0" />
               </effect>
            </VBox>

            <VBox alignment="BOTTOM_CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="btnComenzar" mnemonicParsing="false" onAction="#iniciarCarrera"
                          prefHeight="45.0" prefWidth="180.0"
                          style="-fx-background-color: linear-gradient(#4facfe 0%, #00f2fe 100%); -fx-text-fill: white; -fx-background-radius: 30; -fx-font-weight: bold; -fx-cursor: hand;"
                          text="¡INICIAR CARRERA!">
                     <VBox.margin>
                        <Insets bottom="30.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <effect>
                        <DropShadow color="#000000ab" height="20.0" radius="9.5" width="20.0" />
                     </effect>
                  </Button>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>